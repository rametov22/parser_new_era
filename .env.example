# parse
premiere=365

# --- Vavada proxy pool ---
# One IP or host:port per line. This private file is ignored by Git and copied
# into /app when the Docker image is built.
VAVADA_PROXY_ENABLED=False
VAVADA_PROXY_FILE=.vavada-proxies.txt
VAVADA_PROXY_SCHEME=http
VAVADA_PROXY_PORT=
VAVADA_PROXY_USERNAME=
VAVADA_PROXY_PASSWORD=
# GreyWeb cookies from a verified browser. Keep the values private.
VAVADA_WD_TRUST_COOKIE=
VAVADA_WD_APPROVAL_COOKIE=
# 1 = do not reuse an IP until every address in the pool has been used once.
VAVADA_PROXY_REQUESTS_PER_IP=1
VAVADA_PROXY_MIN_INTERVAL_SECONDS=2
VAVADA_PROXY_CYCLE_COOLDOWN_SECONDS=10
VAVADA_PROXY_FAILURE_COOLDOWN_SECONDS=300
VAVADA_PROXY_LEASE_TTL_SECONDS=300
VAVADA_PROXY_WAIT_TIMEOUT_SECONDS=30
VAVADA_TASK_RATE_LIMIT=60/m
VAVADA_SERIALS_TASK_RATE_LIMIT=60/m

# --- VeoVeo Catalog Sync API ---
# Website token from the VeoVeo account. Do not use the account password here.
VEOVEO_API_TOKEN=
VEOVEO_CATALOG_API_URL=https://catalog-sync-api.rstprgapipt.com
VEOVEO_REQUEST_TIMEOUT_SECONDS=60

# --- MinIO / S3 (постеры, фото актёров, награды) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=kmax-media
MINIO_S3_ENDPOINT_URL=http://minio:9000

# --- Yangi.tv API (AES-ключи извлечены из официального приложения) ---
YT_BEARER_TOKEN=change-me-yangi-bearer-token
YT_AES_KEY=00000000000000000000000000000000
YT_AES_IV_HEX=00000000000000000000000000000000

# --- Kmax backend integration ---
# Публичный URL основного backend Kmax. parser_new_era работает локально (UZ),
# Kmax может быть на удалённом сервере (KZ), поэтому здесь нужен внешний URL.
# Endpoint: {KMAX_INTERNAL_URL}/ru/api/v1/home/internal/yangi/refresh/
# Если пусто — интеграция отключена.
KMAX_INTERNAL_URL=https://kmax.example.com
# Внутренний токен (должен совпадать с YANGI_TV_INTERNAL_TOKEN в .env Kmax).
KMAX_INTERNAL_TOKEN=change-me-internal-token  # openssl rand -hex 32
